{
  "name": "@opencoreagents/code-skills",
  "version": "0.1.2",
  "private": false,
  "license": "Apache-2.0",
  "description": "Agent skill packs (SKILL.md) so Cursor, Claude Code, Codex, etc. know how to use @opencoreagents/* libraries.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "opencoreagents-skills": "./dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup \u0026\u0026 node ./scripts/copy-pack.mjs",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist \u0026\u0026 node ./scripts/clean-skill-docs.mjs"
  },
  "dependencies": {},
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
