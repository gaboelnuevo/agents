{
  "name": "@opencoreagents/skill-loader-openclaw",
  "version": "0.1.2",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "description": "Load OpenClaw / AgentSkills-compatible SKILL.md packs into @opencoreagents/core Skill.define",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openclaw-skill-install": "./dist/cli/install-skill.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "skills:install": "tsx src/cli/install-skill.ts",
    "skills:download": "tsx src/cli/install-skill.ts"
  },
  "dependencies": {
    "@opencoreagents/core": "workspace:*",
    "fflate": "^0.8.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "tsx": "^4.19.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
