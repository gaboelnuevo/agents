# Copy to `.env` in this directory (`apps/runtime/`, next to `docker-compose-with-redis.yml`).
# `.env` is gitignored. Load order: this file is merged into `api` and `worker` before `docker compose up`
# so you do not need to restart containers just to add keys.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional — overrides the compose default (see docker-compose-with-redis.yml)
# REST_API_KEY=
